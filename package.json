{
  "name": "selfagent",
  "version": "0.1.1",
  "type": "module",
  "bin": {
    "selfagent": "selfagent.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "selfagent.mjs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('fs'); fs.chmodSync('dist/main.js', 0o755); fs.chmodSync('selfagent.mjs', 0o755)\"",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.69.0",
    "@mariozechner/pi-coding-agent": "^0.69.0",
    "grammy": "^1.38.3",
    "mime-types": "^3.0.1",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
